# ============================================================
#  RiskShield — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
#  GEMINI API  (free tier — get key at aistudio.google.com)
# ------------------------------------------------------------
VITE_GEMINI_API_KEY=AIzaSyDWt7o0krg7bxoAHENNZNCeGev9O1P7z1g
# ------------------------------------------------------------
#  GEMINI MODEL CONFIG
#  Default: gemini-2.5-flash-preview-04-17
#  Free tier limits: 10 RPM · 250 RPD · 1M TPM
#  NOTE: maxOutputTokens is hardcoded to 65536 (max) in
#        src/agents/geminiClient.js to prevent JSON truncation.
# ------------------------------------------------------------
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_GEMINI_TEMPERATURE=0.15

# ------------------------------------------------------------
#  RAG CONFIG
#  Chunk size (words) and overlap for TF-IDF indexing
# ------------------------------------------------------------
VITE_RAG_CHUNK_SIZE=500
VITE_RAG_CHUNK_OVERLAP=60
VITE_RAG_TOP_K=7

# ------------------------------------------------------------
#  AGENT STAGGER DELAYS (ms)
#  Prevents hitting 10 RPM limit when running parallel agents
# ------------------------------------------------------------
VITE_AGENT_STAGGER_POLICY_MS=1200
VITE_AGENT_STAGGER_MITIGATION_MS=2400
VITE_AGENT_SUMMARY_DELAY_MS=1000

# ------------------------------------------------------------
#  ★  AWS TOGGLE  ★
#
#  false (default) → 100% local, no AWS needed, works as-is
#  true            → enables S3, DynamoDB, Lambda, CloudWatch
#
#  Flip this ONE variable to switch modes:
# ------------------------------------------------------------
VITE_USE_AWS=true

# ------------------------------------------------------------
#  AWS CONFIG  (only needed when VITE_USE_AWS=true)
#
#  Step 1: Deploy the CloudFormation stack:
#            aws/cloudformation.yaml
#          This creates the S3 bucket, DynamoDB table,
#          Lambda function + Function URL, IAM role,
#          and CloudWatch log group automatically.
#
#  Step 2: After deploy, copy the outputs here:
#
#  VITE_AWS_LAMBDA_URL  — Lambda Function URL from CF output
#                         e.g. https://abc123.lambda-url.us-east-1.on.aws
#  VITE_AWS_S3_BUCKET   — S3 bucket name from CF output
#  VITE_AWS_DYNAMO_TABLE — DynamoDB table name from CF output
#  VITE_AWS_REGION      — AWS region you deployed to
#
#  AWS FREE TIER used:
#    Lambda     1M req/mo  +  400K GB-sec compute
#    S3         5 GB       +  20K GET  +  2K PUT/mo
#    DynamoDB   25 GB      +  25 WCU  +  25 RCU/mo
#    CloudWatch 5 GB log ingestion/mo
# ------------------------------------------------------------
VITE_AWS_LAMBDA_URL=https://bsk63pzqowaecbt67v3xqwl7oa0qjgyr.lambda-url.us-east-1.on.aws/
VITE_AWS_S3_BUCKET=rs-ayan-1267119738
VITE_AWS_DYNAMO_TABLE=riskshield-sessions
VITE_AWS_REGION=us-east-1

# ------------------------------------------------------------
#  APP CONFIG
# ------------------------------------------------------------
VITE_APP_NAME=RiskShield
VITE_APP_VERSION=1.0.0
