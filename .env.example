# ============================================================
#  RiskShield — Example env (safe to commit)
#  Copy to .env.local and fill in real values
# ============================================================

VITE_GEMINI_API_KEY=AIzaSyBGqQ6AgkIgUojVwjdisBNVLGr0Tn5QE78
VITE_GEMINI_MODEL=gemini-2.5-flash-lite
VITE_GEMINI_TEMPERATURE=0.15
VITE_RAG_CHUNK_SIZE=500
VITE_RAG_CHUNK_OVERLAP=60
VITE_RAG_TOP_K=7
VITE_AGENT_STAGGER_POLICY_MS=1200
VITE_AGENT_STAGGER_MITIGATION_MS=2400
VITE_AGENT_SUMMARY_DELAY_MS=1000

# ── AWS Toggle (the one variable that controls everything) ──
VITE_USE_AWS=false

# ── AWS values (only needed when VITE_USE_AWS=true) ─────────
VITE_AWS_LAMBDA_URL=
VITE_AWS_S3_BUCKET=riskshield-reports
VITE_AWS_DYNAMO_TABLE=riskshield-sessions
VITE_AWS_REGION=us-east-1

VITE_APP_NAME=RiskShield
VITE_APP_VERSION=1.0.0
